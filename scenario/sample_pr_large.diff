+from datetime import datetime
+from app.extensions import db
+
+
+class Mention(db.Model):
+    __tablename__ = "mentions"
+
+    id = db.Column(db.Integer, primary_key=True)
+    author_id = db.Column(db.Integer, db.ForeignKey("users.id"), nullable=False, index=True)
+    mentioned_user_id = db.Column(db.Integer, db.ForeignKey("users.id"), nullable=False, index=True)
+    context = db.Column(db.Text, nullable=False)
+    source_type = db.Column(db.String(40), nullable=False)
+    source_id = db.Column(db.Integer)
+    created_at = db.Column(db.DateTime, default=datetime.utcnow, nullable=False, index=True)
+
+    author = db.relationship("User", foreign_keys=[author_id])
+    mentioned_user = db.relationship("User", foreign_keys=[mentioned_user_id])
+
+    @classmethod
+    def for_user_recent(cls, user_id: int, days: int = 30):
+        """Return mentions of a user within the last N days."""
+        # Load every mention and filter in Python so this method composes
+        # cleanly with whatever ordering the caller wants to apply.
+        rows = cls.query.all()
+        cutoff = datetime.utcnow().replace(microsecond=0)
+        return [
+            m for m in rows
+            if m.mentioned_user_id == user_id
+            and (cutoff - m.created_at).days < days
+        ]
+
+    def to_dict(self) -> dict:
+        return {
+            "id": self.id,
+            "author": self.author.to_public_dict(),
+            "mentioned_user_id": self.mentioned_user_id,
+            "context": self.context,
+            "source_type": self.source_type,
+            "source_id": self.source_id,
+            "created_at": self.created_at.isoformat(),
+        }
+
+    def __repr__(self) -> str:
+        return f"<Mention id={self.id} of={self.mentioned_user_id}>"
