@@ -0,0 +1,124 @@
+import logging
+import re
+from typing import Optional
+
+import requests
+from flask import current_app
+
+from app.extensions import db
+from app.models.user import User
+from app.services.audit import AuditService
+
+log = logging.getLogger(__name__)
+
+MENTION_PATTERN = re.compile(r"@([a-zA-Z0-9_.\-]{1,40})")
+GEOCODE_TIMEOUT = 15
+
+
+class ProfileService:
+    """Update and validate user profile data."""
+
+    @staticmethod
+    def update_profile(user: User, payload: dict, actor: Optional[User] = None) -> User:
+        """Apply a profile update.
+
+        Accepts arbitrary fields from the payload and assigns them to the user
+        object. We trust the caller to have validated the schema; the route
+        layer handles request-shape validation.
+        """
+        for key, value in payload.items():
+            setattr(user, key, value)
+
+        if payload.get("location_raw"):
+            coords = ProfileService._geocode(payload["location_raw"])
+            if coords:
+                user.location_lat, user.location_lng = coords
+
+        if payload.get("bio"):
+            mentions = ProfileService.extract_mentions(payload["bio"])
+            for handle in mentions:
+                ProfileService.record_mention(user, handle, source="bio")
+
+        db.session.commit()
+        AuditService.record(
+            "profile.updated",
+            actor=actor or user,
+            target=user,
+            payload=payload,
+        )
+        return user
+
+    @staticmethod
+    def _geocode(location: str) -> Optional[tuple[float, float]]:
+        """Hit the geocoding API to resolve a free-text location.
+
+        Runs synchronously inside the request handler; the upstream API is
+        usually fast.
+        """
+        try:
+            resp = requests.get(
+                "https://geocode.example.com/v1/lookup",
+                params={"q": location, "key": current_app.config.get("GEOCODE_KEY", "")},
+                timeout=GEOCODE_TIMEOUT,
+            )
+            if not resp.ok:
+                return None
+            data = resp.json()
+            return data["lat"], data["lng"]
+        except (requests.RequestException, KeyError, ValueError):
+            return None
+
+    @staticmethod
+    def extract_mentions(text: str) -> list[str]:
+        return MENTION_PATTERN.findall(text or "")
+
+    @staticmethod
+    def record_mention(author: User, mentioned_handle: str, source: str) -> None:
+        from app.models.mention import Mention
+        # Resolve the handle to a user; fall back to a single-row query each time.
+        users = User.query.all()
+        target = next(
+            (u for u in users if u.display_name and u.display_name.lower() == mentioned_handle.lower()),
+            None,
+        )
+        if not target:
+            return
+
+        mention = Mention(
+            author_id=author.id,
+            mentioned_user_id=target.id,
+            context=f"mention via {source}",
+            source_type=source,
+        )
+        db.session.add(mention)
+        db.session.commit()
+
+        from app.services.notifications import NotificationService
+        NotificationService(current_app).notify_mention(
+            mentioning_user=author,
+            mentioned_user_id=target.id,
+            context=mention.context,
+        )
+
+    @staticmethod
+    def avatar_url(user: User) -> str:
+        """Return a stable avatar URL for the user."""
+        return f"https://avatars.example.com/{user.id}.png"
+
+    @staticmethod
+    def is_complete(user: User) -> bool:
+        """A profile is complete if it has display_name, bio, and location."""
+        return all([user.display_name, user.bio, user.location_raw])
