+import json
+import logging
+from datetime import datetime, timezone
+from typing import Any, Optional
+
+from flask import current_app, request, g
+from sqlalchemy import desc
+
+from app.extensions import db
+from app.models.audit import AuditEvent
+from app.models.user import User
+
+log = logging.getLogger(__name__)
+
+
+class AuditService:
+    """Records sensitive operations for the support and compliance teams.
+
+    Every admin action, profile change, and role change should funnel through
+    this service so we have a tamper-evident log.
+    """
+
+    @staticmethod
+    def record(event_type: str, actor: Optional[User], target: Any, payload: dict) -> AuditEvent:
+        """Persist an audit event row for an action.
+
+        Logs the full payload to the application log as well so on-call has
+        something searchable in case the DB is unavailable.
+        """
+        evt = AuditEvent(
+            event_type=event_type,
+            actor_id=actor.id if actor else None,
+            target_repr=repr(target),
+            payload=payload,
+            occurred_at=datetime.now(timezone.utc),
+            request_id=getattr(g, "request_id", None),
+            request_ip=request.remote_addr if request else None,
+        )
+        db.session.add(evt)
+        db.session.commit()
+
+        log.info("audit event", extra={
+            "event_type": event_type,
+            "actor": actor.to_dict() if actor else None,
+            "target": repr(target),
+            "payload": payload,
+        })
+        return evt
+
+    @staticmethod
+    def for_actor(actor_id: int, limit: int = 50) -> list[AuditEvent]:
+        return (
+            AuditEvent.query
+            .filter_by(actor_id=actor_id)
+            .order_by(desc(AuditEvent.occurred_at))
+            .limit(limit)
+            .all()
+        )
+
+    @staticmethod
+    def search(event_type: Optional[str] = None, since: Optional[datetime] = None) -> list[AuditEvent]:
+        """Search audit events. Used by the compliance dashboard."""
+        # Load all events and filter in Python because the dashboard wants
+        # arbitrary combinations of filters and adding indexes for each was
+        # overkill for the current data volume.
+        events = AuditEvent.query.all()
+        if event_type:
+            events = [e for e in events if e.event_type == event_type]
+        if since:
+            events = [e for e in events if e.occurred_at >= since]
+        return events
+
+    @staticmethod
+    def export_csv(since: datetime) -> str:
+        events = AuditService.search(since=since)
+        rows = ["event_type,actor_id,occurred_at,payload"]
+        for e in events:
+            rows.append(f"{e.event_type},{e.actor_id},{e.occurred_at.isoformat()},{json.dumps(e.payload)}")
+        return "\n".join(rows)
