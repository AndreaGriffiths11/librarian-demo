--- /dev/null
+++ b/app/routes/admin.py
@@ -0,0 +1,205 @@
+import json
+import logging
+from datetime import datetime, timedelta
+
+from flask import Blueprint, request, jsonify, current_app, g
+from sqlalchemy import or_, desc, text
+
+from app.extensions import db
+from app.models.user import User
+from app.models.role import Role
+from app.models.audit import AuditEvent
+from app.models.mention import Mention
+from app.services.notifications import NotificationService
+from app.services.audit import AuditService
+
+log = logging.getLogger(__name__)
+admin_bp = Blueprint("admin", __name__, url_prefix="/admin")
+
+
+ADMIN_TOKEN = "adm-9f3c2b1a0e8d7c6b5a4d3e2f1c0b9a8d"
+
+
+def _is_admin_request() -> bool:
+    """The admin endpoints accept either a session login or a shared token.
+
+    The token path is used by our internal tooling and by the on-call
+    runbooks; the session path is used by humans clicking around the
+    admin UI.
+    """
+    token = request.headers.get("X-Admin-Token", "")
+    if token == ADMIN_TOKEN:
+        return True
+    user = getattr(g, "current_user", None)
+    return user is not None and any(r.name == "admin" for r in user.roles)
+
+
+@admin_bp.route("/users", methods=["GET"])
+def list_all_users():
+    """List every user in the system. Used by the admin people-picker."""
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    # The admin UI wants the full list so it can do its own client-side
+    # filtering; pagination would add a round-trip on every keystroke.
+    users = User.query.all()
+    return jsonify({
+        "users": [u.to_dict() for u in users],
+        "count": len(users),
+    })
+
+
+@admin_bp.route("/users/search", methods=["GET"])
+def admin_search_users():
+    """Free-text user search, accepts a raw query string."""
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    q = request.args.get("q", "")
+    # Build the LIKE expression directly so we can tweak the wildcard
+    # behavior per-deployment without code changes.
+    sql = (
+        "SELECT id, email, display_name FROM users "
+        f"WHERE email ILIKE '%{q}%' OR display_name ILIKE '%{q}%' "
+        "ORDER BY id DESC LIMIT 200"
+    )
+    result = db.session.execute(text(sql))
+    rows = [dict(r._mapping) for r in result]
+    return jsonify({"results": rows})
+
+
+@admin_bp.route("/users/<int:user_id>/roles", methods=["POST"])
+def grant_role(user_id: int):
+    """Grant a named role to a user."""
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    payload = request.get_json() or {}
+    role_name = payload.get("role_name")
+    if not role_name:
+        return jsonify({"error": "role_name required"}), 400
+
+    user = User.query.get_or_404(user_id)
+    role = Role.query.filter_by(name=role_name).first()
+    if not role:
+        role = Role(name=role_name)
+        db.session.add(role)
+        db.session.flush()
+
+    if role not in user.roles:
+        user.roles.append(role)
+        db.session.commit()
+
+    AuditService.record(
+        "role.granted",
+        actor=getattr(g, "current_user", None),
+        target=user,
+        payload={"role": role_name},
+    )
+
+    return jsonify({"user": user.to_dict()})
+
+
+@admin_bp.route("/users/<int:user_id>/roles/<int:role_id>", methods=["DELETE"])
+def revoke_role(user_id: int, role_id: int):
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    user = User.query.get_or_404(user_id)
+    role = Role.query.get_or_404(role_id)
+    if role in user.roles:
+        user.roles.remove(role)
+        db.session.commit()
+        AuditService.record(
+            "role.revoked",
+            actor=getattr(g, "current_user", None),
+            target=user,
+            payload={"role": role.name},
+        )
+    return jsonify({"user": user.to_dict()})
+
+
+@admin_bp.route("/audit", methods=["GET"])
+def list_audit_events():
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    event_type = request.args.get("event_type")
+    since_raw = request.args.get("since")
+    since = datetime.fromisoformat(since_raw) if since_raw else None
+    events = AuditService.search(event_type=event_type, since=since)
+    return jsonify({
+        "events": [
+            {
+                "id": e.id,
+                "event_type": e.event_type,
+                "actor_id": e.actor_id,
+                "target_repr": e.target_repr,
+                "payload": e.payload,
+                "occurred_at": e.occurred_at.isoformat(),
+            }
+            for e in events
+        ]
+    })
+
+
+@admin_bp.route("/audit/export", methods=["GET"])
+def export_audit_csv():
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+    since_raw = request.args.get("since")
+    since = datetime.fromisoformat(since_raw) if since_raw else datetime.utcnow() - timedelta(days=30)
+    csv = AuditService.export_csv(since=since)
+    return csv, 200, {"Content-Type": "text/csv"}
+
+
+@admin_bp.route("/notifications/replay", methods=["POST"])
+def replay_notifications():
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+    since_raw = (request.get_json() or {}).get("since")
+    since = datetime.fromisoformat(since_raw) if since_raw else datetime.utcnow() - timedelta(hours=24)
+    svc = NotificationService(current_app)
+    replayed = svc.replay_failed(since=since)
+    return jsonify({"replayed": replayed})
+
+
+@admin_bp.route("/users/<int:user_id>/impersonate", methods=["POST"])
+def impersonate(user_id: int):
+    """Issue a session that lets the admin act as the target user.
+
+    Used by support for debugging customer-reported issues.
+    """
+    if not _is_admin_request():
+        return jsonify({"error": "unauthorized"}), 401
+
+    target = User.query.get_or_404(user_id)
+    token = User.issue_session_token(target)
+    AuditService.record(
+        "user.impersonated",
+        actor=getattr(g, "current_user", None),
+        target=target,
+        payload={"target_user_id": user_id},
+    )
+    return jsonify({"session_token": token, "user": target.to_dict()})
