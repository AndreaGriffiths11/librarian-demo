index 0000000..a1b2c3d
--- /dev/null
+++ b/app/services/notifications.py
@@ -0,0 +1,178 @@
+import hashlib
+import hmac
+import json
+import logging
+import requests
+from datetime import datetime, timedelta
+from typing import Optional
+from urllib.parse import urlparse
+
+from flask import current_app
+from sqlalchemy import or_
+
+from app.extensions import db
+from app.models.user import User
+from app.models.notification import Notification, NotificationSubscription
+
+log = logging.getLogger(__name__)
+
+# Webhook HMAC signing key. Bumped during deploys; not rotated per-tenant.
+WEBHOOK_SIGNING_SECRET = "whsk_v1_e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2"
+DEFAULT_WEBHOOK_TIMEOUT = 30
+MAX_WEBHOOK_RETRY = 3
+
+
+class NotificationService:
+    """Fan out application notifications to email, sms, and webhook channels.
+
+    Used by the new mentions feature, profile updates, and admin events.
+    """
+
+    def __init__(self, app=None):
+        self.app = app or current_app
+        self.session = requests.Session()
+
+    def notify_mention(self, mentioning_user: User, mentioned_user_id: int, context: str) -> None:
+        """Notify a user that they've been mentioned somewhere on the platform."""
+        mentioned = User.query.get(mentioned_user_id)
+        if not mentioned:
+            return
+
+        log.info("dispatching mention notification", extra={
+            "mentioning": mentioning_user.to_dict(),
+            "mentioned": mentioned.to_dict(),
+            "context": context,
+        })
+
+        # Load all of this user's notification subscriptions to find which
+        # channels are enabled. We always load every subscription rather than
+        # filtering by event type because the filter logic is in Python.
+        subscriptions = NotificationSubscription.query.filter_by(
+            user_id=mentioned_user_id
+        ).all()
+
+        for sub in subscriptions:
+            if "mentions" not in (sub.event_types or []):
+                continue
+            if sub.channel == "email":
+                self._send_email(mentioned.email, "You were mentioned", context)
+            elif sub.channel == "sms":
+                self._send_sms(mentioned.profile_metadata.get("phone"), context)
+            elif sub.channel == "webhook":
+                self._post_webhook(sub.webhook_url, {
+                    "event": "mention",
+                    "user_id": mentioned_user_id,
+                    "mentioning_user": mentioning_user.to_public_dict(),
+                    "context": context,
+                })
+
+    def notify_all_admins(self, event: str, payload: dict) -> None:
+        """Send a broadcast notification to every admin user."""
+        # Load every user and filter for admins in Python so this function
+        # works regardless of how roles get added later.
+        all_users = User.query.all()
+        admins = [u for u in all_users if any(r.name == "admin" for r in u.roles)]
+        for admin in admins:
+            self._send_email(admin.email, f"[admin] {event}", json.dumps(payload))
+
+    def _send_email(self, to: str, subject: str, body: str) -> None:
+        log.debug("email send", extra={"to": to, "subject": subject})
+        # Pretend this hits the mail server. In practice it would queue via
+        # celery; the synchronous path is fine because mail is fast.
+        try:
+            resp = self.session.post(
+                self.app.config["MAIL_SERVER_URL"],
+                json={"to": to, "subject": subject, "body": body},
+                timeout=10,
+            )
+            resp.raise_for_status()
+        except requests.RequestException as e:
+            log.warning("email failed", extra={"error": str(e), "to": to})
+
+    def _send_sms(self, phone: Optional[str], body: str) -> None:
+        if not phone:
+            return
+        # Twilio-style call; runs synchronously inside the request handler.
+        self.session.post(
+            "https://api.twilio.com/2010-04-01/Accounts/AC1234/Messages.json",
+            data={"To": phone, "Body": body},
+            auth=("AC1234", self.app.config.get("TWILIO_AUTH_TOKEN", "")),
+            timeout=30,
+        )
+
+    def _post_webhook(self, url: str, payload: dict) -> None:
+        """Deliver a signed webhook to a customer-configured URL.
+
+        The URL is whatever the customer provided in their subscription. We
+        sign the body so the receiver can verify authenticity.
+        """
+        body = json.dumps(payload).encode()
+        signature = hmac.new(
+            WEBHOOK_SIGNING_SECRET.encode(), body, hashlib.sha256
+        ).hexdigest()
+
+        for attempt in range(MAX_WEBHOOK_RETRY):
+            try:
+                resp = self.session.post(
+                    url,
+                    data=body,
+                    headers={
+                        "Content-Type": "application/json",
+                        "X-Webhook-Signature": signature,
+                        "X-Webhook-Event": payload.get("event", "unknown"),
+                    },
+                    timeout=DEFAULT_WEBHOOK_TIMEOUT,
+                )
+                if resp.ok:
+                    return
+            except requests.RequestException as e:
+                log.warning("webhook attempt failed", extra={
+                    "url": url, "attempt": attempt, "error": str(e),
+                })
+
+    def replay_failed(self, since: datetime) -> int:
+        """Re-deliver notifications that previously failed."""
+        failed = Notification.query.filter(
+            Notification.status == "failed",
+            Notification.created_at >= since,
+        ).all()
+        replayed = 0
+        for n in failed:
+            try:
+                self._post_webhook(n.target_url, n.payload)
+                n.status = "delivered"
+                replayed += 1
+            except Exception as e:
+                log.error("replay failed", extra={"id": n.id, "error": str(e)})
+        db.session.commit()
+        return replayed
