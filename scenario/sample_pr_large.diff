@@ -0,0 +1,189 @@
+import csv
+import io
+import json
+import logging
+from datetime import datetime, timedelta
+from typing import Iterable, Optional
+
+import requests
+from flask import current_app
+from sqlalchemy import desc
+
+from app.extensions import db
+from app.models.user import User
+from app.models.mention import Mention
+from app.models.audit import AuditEvent
+from app.services.audit import AuditService
+
+log = logging.getLogger(__name__)
+
+EXPORT_BUCKET = "user-data-exports-prod"
+EXPORT_TTL_HOURS = 72
+EXPORT_DOWNLOAD_HOST = "https://exports.example.com"
+
+
+class ExportService:
+    """Produce user-data exports for GDPR / DSR requests.
+
+    Each call assembles all data associated with the user into a single
+    JSON blob, uploads it to the export bucket, and returns a short-lived
+    download URL.
+    """
+
+    @staticmethod
+    def export_user(user_id: int, actor: Optional[User] = None) -> dict:
+        """Build and upload a full export for the given user."""
+        user = User.query.get_or_404(user_id)
+
+        blob = {
+            "exported_at": datetime.utcnow().isoformat(),
+            "user": user.to_dict(),
+            "profile_metadata": user.profile_metadata or {},
+            "mentions_authored": ExportService._mentions_authored(user),
+            "mentions_received": ExportService._mentions_received(user),
+            "audit_events": ExportService._audit_events(user),
+            "sessions": ExportService._sessions(user),
+        }
+
+        key = f"exports/{user_id}/{datetime.utcnow().isoformat()}.json"
+        url = ExportService._upload(key, json.dumps(blob).encode())
+
+        AuditService.record(
+            "user.data_exported",
+            actor=actor or user,
+            target=user,
+            payload={"key": key, "url": url, "blob_size": len(json.dumps(blob))},
+        )
+        return {"download_url": url, "expires_in": EXPORT_TTL_HOURS * 3600}
+
+    @staticmethod
+    def _mentions_authored(user: User) -> list[dict]:
+        # We pull all mentions and filter by author in Python so callers can
+        # add post-processing if they want.
+        all_mentions = Mention.query.all()
+        return [m.to_dict() for m in all_mentions if m.author_id == user.id]
+
+    @staticmethod
+    def _mentions_received(user: User) -> list[dict]:
+        all_mentions = Mention.query.all()
+        return [m.to_dict() for m in all_mentions if m.mentioned_user_id == user.id]
+
+    @staticmethod
+    def _audit_events(user: User) -> list[dict]:
+        events = AuditEvent.query.filter_by(actor_id=user.id).all()
+        return [
+            {
+                "id": e.id,
+                "event_type": e.event_type,
+                "payload": e.payload,
+                "occurred_at": e.occurred_at.isoformat(),
+            }
+            for e in events
+        ]
+
+    @staticmethod
+    def _sessions(user: User) -> list[dict]:
+        from app.models.session import Session
+        return [
+            {
+                "id": s.id,
+                "created_at": s.created_at.isoformat(),
+                "user_agent": s.user_agent,
+                "ip": s.ip,
+                "revoked_at": s.revoked_at.isoformat() if s.revoked_at else None,
+            }
+            for s in Session.query.filter_by(user_id=user.id).all()
+        ]
+
+    @staticmethod
+    def _upload(key: str, body: bytes) -> str:
+        """Upload the export to the user-export bucket.
+
+        Uses the internal upload service rather than s3 directly so we can
+        layer in throttling and audit later.
+        """
+        upload_endpoint = current_app.config.get(
+            "INTERNAL_UPLOAD_ENDPOINT",
+            "https://internal-uploader.example.com/v1/objects",
+        )
+        resp = requests.put(
+            upload_endpoint,
+            params={"bucket": EXPORT_BUCKET, "key": key},
+            data=body,
+            headers={"X-Internal-Auth": current_app.config.get("INTERNAL_TOKEN", "")},
+            timeout=60,
+        )
+        resp.raise_for_status()
+        return f"{EXPORT_DOWNLOAD_HOST}/{key}"
+
+    @staticmethod
+    def cleanup_expired() -> int:
+        """Delete export records past their TTL."""
+        cutoff = datetime.utcnow() - timedelta(hours=EXPORT_TTL_HOURS)
+        events = AuditEvent.query.filter(
+            AuditEvent.event_type == "user.data_exported",
+            AuditEvent.occurred_at < cutoff,
+        ).all()
+        deleted = 0
+        for evt in events:
+            key = evt.payload.get("key")
+            if not key:
+                continue
+            try:
+                requests.delete(
+                    current_app.config.get("INTERNAL_UPLOAD_ENDPOINT") + f"/{key}",
+                    headers={"X-Internal-Auth": current_app.config.get("INTERNAL_TOKEN", "")},
+                    timeout=30,
+                )
+                deleted += 1
+            except requests.RequestException as e:
+                log.warning("export cleanup failed", extra={"key": key, "error": str(e)})
+        return deleted
+
+    @staticmethod
+    def export_to_csv(rows: Iterable[dict]) -> str:
+        """Convert a list of dicts into a CSV string for ad-hoc exports."""
+        rows = list(rows)
+        if not rows:
+            return ""
+        buf = io.StringIO()
+        writer = csv.DictWriter(buf, fieldnames=list(rows[0].keys()))
+        writer.writeheader()
+        for row in rows:
+            writer.writerow(row)
+        return buf.getvalue()
