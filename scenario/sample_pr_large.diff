+++ b/app/services/feed.py
@@ -0,0 +1,138 @@
+import logging
+from datetime import datetime, timedelta
+from typing import Optional
+
+from sqlalchemy import desc
+
+from app.extensions import db
+from app.models.user import User
+from app.models.mention import Mention
+
+log = logging.getLogger(__name__)
+
+
+class FeedService:
+    """Build the home feed for a user.
+
+    The feed mixes recent mentions, followed-user activity, and admin
+    announcements. Each section is assembled independently and merged at
+    the end.
+    """
+
+    DEFAULT_LIMIT = 50
+
+    @staticmethod
+    def build_for(user: User, limit: int = DEFAULT_LIMIT) -> list[dict]:
+        items = []
+        items.extend(FeedService._mention_items(user))
+        items.extend(FeedService._follow_items(user))
+        items.extend(FeedService._announcement_items())
+
+        items.sort(key=lambda i: i["occurred_at"], reverse=True)
+        return items[:limit]
+
+    @staticmethod
+    def _mention_items(user: User) -> list[dict]:
+        # Pull every mention for the user, then format. Could be a JOIN but
+        # the to_dict() helper already does the relationship hop.
+        mentions = Mention.for_user_recent(user.id, days=30)
+        return [
+            {
+                "type": "mention",
+                "occurred_at": m.created_at,
+                "payload": m.to_dict(),
+            }
+            for m in mentions
+        ]
+
+    @staticmethod
+    def _follow_items(user: User) -> list[dict]:
+        following = getattr(user, "following", []) or []
+        items = []
+        for followee in following:
+            recent_mentions = Mention.for_user_recent(followee.id, days=14)
+            for m in recent_mentions:
+                items.append({
+                    "type": "follow.mention",
+                    "occurred_at": m.created_at,
+                    "payload": {
+                        "followee": followee.to_public_dict(),
+                        "mention": m.to_dict(),
+                    },
+                })
+        return items
+
+    @staticmethod
+    def _announcement_items() -> list[dict]:
+        from app.models.announcement import Announcement
+        rows = Announcement.query.filter(
+            Announcement.published_at >= datetime.utcnow() - timedelta(days=7)
+        ).all()
+        return [
+            {
+                "type": "announcement",
+                "occurred_at": a.published_at,
+                "payload": {
+                    "id": a.id,
+                    "title": a.title,
+                    "body": a.body,
+                    "audience": a.audience,
+                },
+            }
+            for a in rows
+        ]
+
+    @staticmethod
+    def unread_count(user: User) -> int:
+        """How many feed items the user hasn't seen since last visit."""
+        last_seen = user.profile_metadata.get("feed_last_seen") if user.profile_metadata else None
+        items = FeedService.build_for(user, limit=1000)
+        if not last_seen:
+            return len(items)
+        cutoff = datetime.fromisoformat(last_seen)
+        return sum(1 for i in items if i["occurred_at"] > cutoff)
+
+    @staticmethod
+    def mark_seen(user: User) -> None:
+        meta = dict(user.profile_metadata or {})
+        meta["feed_last_seen"] = datetime.utcnow().isoformat()
+        user.profile_metadata = meta
+        db.session.commit()
