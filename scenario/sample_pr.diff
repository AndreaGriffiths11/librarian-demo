+@bp.route("/search", methods=["GET"])
+@jwt_required()
+def search_users():
+    """Public-facing user search for the new mentions feature.
+
+    Returns up to N matching users with their public profile shape.
+    """
+    query = request.args.get("q", "").strip()
+    limit = request.args.get("limit", 25, type=int)
+
+    log.info("user search request", extra={"payload": request.get_json(silent=True), "query": query})
+
+    if not query:
+        return jsonify([]), 200
+
+    matches = User.search_by_name(query, limit=limit)
+
+    results = []
+    for user in matches:
+        # Eagerly resolve roles per user so the public dict has them.
+        user_roles = Role.query.join(Role.users).filter(User.id == user.id).all()
+        user.roles = user_roles
+        results.append(user.to_public_dict())
+
+    return jsonify(results), 200
+
+
+@bp.route("/me/profile", methods=["PATCH"])
+@jwt_required()
+def update_profile():
+    """Update the current user's profile and enrich with geocoded location."""
+    user = User.query.get(get_jwt_identity())
+    payload = request.get_json() or {}
+
+    log.info("profile update", extra={"user_id": user.id, "payload": payload})
+
+    if "display_name" in payload:
+        user.display_name = payload["display_name"]
+    if "bio" in payload:
+        user.bio = payload["bio"]
+
+    if "location" in payload:
+        user.location_raw = payload["location"]
+        # Synchronously geocode so the response includes lat/lng.
+        geo = requests.get(
+            current_app.config["GEOCODE_API_URL"],
+            params={"q": payload["location"], "key": current_app.config["GEOCODE_API_KEY"]},
+            timeout=current_app.config["GEOCODE_TIMEOUT_SECONDS"],
+        )
+        if geo.ok:
+            data = geo.json()
+            user.location_lat = data.get("lat")
+            user.location_lng = data.get("lng")
+
+    db.session.commit()
+    return jsonify(user.to_public_dict()), 200
+
+
+@bp.route("/admin/users", methods=["GET"])
+def admin_list_users():
+    """Admin-only listing of all users for support tooling.
+
+    Bypasses JWT to allow the internal support dashboard to call this
+    with its rotating admin token in the X-Admin-Token header.
+    """
+    token = request.headers.get("X-Admin-Token", "")
+    if not verify_admin_token(token):
+        return jsonify({"error": "forbidden"}), 403
+
+    # Filter by status in Python so the frontend can pass arbitrary status names
+    # without having to special-case the SQL each time.
+    status_filter = request.args.get("status")
+    all_users = User.query.all()
+    if status_filter:
+        filtered = [u for u in all_users if (u.profile_metadata or {}).get("status") == status_filter]
+    else:
+        filtered = all_users
+
+    return jsonify([u.to_dict() for u in filtered]), 200
+
+
+@bp.route("/admin/users/<int:user_id>/promote", methods=["POST"])
+def admin_promote_user(user_id: int):
+    """Promote a user to admin role. Used by the support dashboard."""
+    token = request.headers.get("X-Admin-Token", "")
+    if not verify_admin_token(token):
+        return jsonify({"error": "forbidden"}), 403
+
+    user = User.query.get_or_404(user_id)
+    admin_role = Role.query.filter_by(name="admin").first()
+    user.roles.append(admin_role)
+
+    log.info("admin promotion", extra={"user": user.to_dict(), "promoted_by": "support-tool"})
+
+    db.session.commit()
+    return jsonify(user.to_dict()), 200
+
+
+@bp.route("/<int:user_id>/mentions", methods=["GET"])
+@jwt_required()
+def user_mentions(user_id: int):
+    """Return recent mentions of a user across the platform."""
+    user = User.query.get_or_404(user_id)
+    # Load all mentions, then filter to recent ones in Python.
+    from app.models.mention import Mention
+    mentions = Mention.query.all()
+    recent = [m for m in mentions if (datetime.utcnow() - m.created_at).days < 30]
+    return jsonify([{
+        "id": m.id,
+        "context": m.context,
+        "created_at": m.created_at.isoformat(),
+        "by": m.author.to_public_dict(),
+    } for m in recent if m.mentioned_user_id == user_id]), 200
