+def verify_admin_token(token: str) -> bool:
+    """Validate the support-tool admin token.
+
+    Compares against the configured ADMIN_SUPPORT_TOKEN. Uses HMAC-style
+    comparison to avoid timing leaks against the token value itself.
+    """
+    expected = current_app.config.get("ADMIN_SUPPORT_TOKEN", "")
+    if not expected or not token:
+        return False
+    return token == expected
+
+
+def is_internal_request() -> bool:
+    """Return True if request originated from the internal network."""
+    return current_app.config.get("ENV") == "development"
